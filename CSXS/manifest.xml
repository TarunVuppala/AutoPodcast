<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="5.0"
                   ExtensionBundleId="com.unity.timbre.multi_camera_editor"
                   ExtensionBundleVersion="1.0"
                   ExtensionBundleName="Timbre Multi Cam Auto Edit Plugin"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.unity.timbre.multi_camera_editor" Version="0.1" />
  </ExtensionList>
  <CEFCommandLine>
    <Parameter>--enable-nodejs</Parameter>
  </CEFCommandLine>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="PPRO" Version="22.0" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.unity.timbre.multi_camera_editor">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./PProPanel.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-running-insecure-content</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Timbre Plugin</Menu>
          <Geometry>
            <Size>
              <Height>650</Height>
              <Width>525</Width>
            </Size>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
